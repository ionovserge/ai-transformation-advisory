              whileInView={{ opacity: 1, y: 0 }}
              viewport={{ once: true }}
              onClick={() => setSelectedCase(c)}
              className="group cursor-pointer bg-slate-900/50 border border-slate-800 p-8 rounded-[40px] hover:bg-slate-800/80 hover:shadow-2xl hover:border-blue-900/50 transition-all duration-500 flex flex-col overflow-hidden relative"
            >
              {/* Фоновое свечение (Glow effect) */}
              <div className="absolute -top-24 -right-24 w-48 h-48 bg-blue-600/5 blur-[80px] group-hover:bg-blue-600/10 transition-all duration-700" />
              
              <div className="flex items-start justify-between mb-8 relative z-10">
                {/* НОВЫЙ ДИЗАЙН ИКОНКИ (Tech Core Style) */}
