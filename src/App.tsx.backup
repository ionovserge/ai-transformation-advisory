                key={cat.id}
                onClick={() => setActiveTab(cat.id)}
                className={`flex items-center gap-2.5 px-6 py-3 rounded-xl text-sm font-bold transition-all duration-300 ${
                  activeTab === cat.id 
                    ? 'bg-slate-900 text-white shadow-lg' 
                    : 'text-slate-500 hover:text-slate-900 hover:bg-slate-50'
                }`}
              >
                <cat.icon size={18} strokeWidth={activeTab === cat.id ? 2 : 1.5} />
                {cat.label}
              </button>
            ))}
          </div>
        </div>

        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <AnimatePresence mode="popLayout">
            {filteredSolutions.map((sol) => (
              <motion.div
                layout
                key={sol.id}
                initial={{ opacity: 0, scale: 0.95 }}
                animate={{ opacity: 1, scale: 1 }}
                exit={{ opacity: 0, scale: 0.95 }}
                transition={{ duration: 0.3 }}
                onClick={() => setSelectedSolution(sol)}
                className="group p-10 bg-white rounded-[40px] border border-slate-200/60 hover:border-blue-500/30 hover:shadow-[0_32px_64px_-16px_rgba(0,0,0,0.08)] transition-all duration-500 cursor-pointer flex flex-col h-full relative overflow-hidden"
              >
                {/* Едва заметный градиент при ховере */}
                <div className="absolute inset-0 bg-gradient-to-br from-blue-50/0 to-indigo-50/0 group-hover:from-blue-50/40 group-hover:to-indigo-50/40 transition-all duration-500" />
                
                <div className="relative z-10 flex flex-col h-full">
                  {/* ИКОНКА (Minimalist Ghost Style) */}
                  <div className="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-400 mb-8 group-hover:bg-blue-600 group-hover:text-white transition-all duration-500 shadow-inner">
                    <sol.icon size={28} strokeWidth={1.5} />
                  </div>
                  
                  <div className="mb-6">
                    <h3 className="text-2xl font-bold text-slate-900 mb-2 tracking-tight group-hover:text-blue-700 transition-colors">{sol.title}</h3>
                    <div className="text-[10px] font-black text-blue-600 uppercase tracking-widest">{sol.subtitle || 'Solution Architecture'}</div>
                  </div>
                  
                  <p className="text-slate-500 text-sm leading-relaxed mb-8 font-medium">
                    {sol.content}
                  </p>
                  
                  <div className="mt-auto pt-6 border-t border-slate-50 flex items-center justify-between">
                    <span className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">{sol.industry}</span>
                    <div className="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-300 group-hover:bg-blue-50 group-hover:text-blue-600 transition-all">
                      <ArrowRight size={16} />
                    </div>
                  </div>
                </div>
              </motion.div>
            ))}
          </AnimatePresence>
        </div>
      </div>

      {/* Detail Modal (Light Minimalist) */}
      <AnimatePresence>
        {selectedSolution && (
          <div className="fixed inset-0 z-[110] flex items-center justify-center p-4 md:p-6 text-slate-900">
            <motion.div 
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              onClick={() => setSelectedSolution(null)}
              className="absolute inset-0 bg-slate-900/40 backdrop-blur-md"
            />
            <motion.div
              initial={{ opacity: 0, scale: 0.95, y: 20 }}
              animate={{ opacity: 1, scale: 1, y: 0 }}
              exit={{ opacity: 0, scale: 0.95, y: 20 }}
              className="relative w-full max-w-4xl bg-white rounded-[40px] shadow-[0_40px_80px_-20px_rgba(0,0,0,0.2)] overflow-hidden flex flex-col max-h-[90vh] border border-slate-200"
            >
              {/* ШАПКА МОДАЛКИ (Light Tech) */}
              <div className="shrink-0 h-32 md:h-44 bg-slate-50 p-8 md:p-10 flex items-end justify-between relative overflow-hidden border-b border-slate-100">
                {/* Фоновое свечение (едва заметное) */}
                <div className="absolute top-[-50%] left-[-10%] w-[60%] h-[150%] rounded-full bg-blue-500/5 blur-[80px]" />
                
                <div className="flex items-center gap-6 relative z-10">
                  <div className="w-16 h-16 md:w-20 md:h-20 bg-white border border-slate-200 rounded-2xl md:rounded-3xl flex items-center justify-center text-blue-600 shadow-sm relative">
                    <selectedSolution.icon size={32} strokeWidth={1.5} className="md:w-10 md:h-10" />
                    {/* Точка активности */}
                    <div className="absolute top-2 right-2 w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.5)]" />
                  </div>
                  <div>
                    <div className="text-[10px] font-black uppercase tracking-[0.3em] text-blue-600 mb-2">{selectedSolution.category_label || 'Architecture'}</div>
                    <h3 className="text-2xl md:text-4xl font-bold tracking-tight">{selectedSolution.title}</h3>
                  </div>
                </div>

                <button 
                  onClick={() => setSelectedSolution(null)}
                  className="absolute top-6 right-6 w-10 h-10 bg-white rounded-full flex items-center justify-center text-slate-400 hover:text-slate-900 hover:shadow-lg transition-all border border-slate-200 z-20"
                >
                  <X size={20} />
                </button>
              </div>
              
              <div className="p-8 md:p-12 overflow-y-auto custom-scrollbar bg-white">
                <div className="grid grid-cols-1 lg:grid-cols-3 gap-12">
                  <div className="lg:col-span-2 space-y-10">
                    {/* Description Section */}
                    <div>
                      <h4 className="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-4">Суть решения</h4>
                      <p className="text-xl text-slate-700 leading-relaxed font-medium">
                        {selectedSolution.content}
                      </p>
                    </div>

                    {/* Problem/Pain Section */}
                    {selectedSolution.pain && (
                      <div className="bg-slate-50 p-8 rounded-3xl border border-slate-100">
                        <h4 className="text-[10px] font-black text-red-500 uppercase tracking-[0.2em] mb-4">Бизнес-боль</h4>
                        <p className="text-slate-600 leading-relaxed">{selectedSolution.pain}</p>
                      </div>
                    )}

                    {/* Agents Section */}
                    {selectedSolution.agents && (
                      <div>
                        <h4 className="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-6">Автономные AI-агенты</h4>
                        <div className="grid grid-cols-1 gap-4">
                          {selectedSolution.agents.map((agent: any, idx: number) => (
                            <div key={idx} className="group/agent p-6 bg-white border border-slate-100 rounded-2xl hover:border-blue-200 hover:shadow-md transition-all duration-300">
                              <div className="flex items-center gap-4 mb-2">
                                <div className="w-2 h-2 rounded-full bg-blue-500 opacity-40 group-hover/agent:opacity-100 transition-opacity" />
                                <div className="font-bold text-slate-900">{agent.name}</div>
                              </div>
                              <div className="text-slate-500 text-sm leading-relaxed pl-6">{agent.task}</div>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>

                  <div className="space-y-8">
                    {/* Metrics Section */}
                    <section className="bg-blue-600 p-8 rounded-[40px] text-white shadow-xl shadow-blue-100 relative overflow-hidden">
                      {/* Декор для метрик */}
                      <div className="absolute top-[-20%] right-[-20%] w-32 h-32 bg-white/10 rounded-full blur-2xl" />
                      
                      <h4 className="text-[10px] font-black text-white/60 uppercase tracking-[0.2em] mb-8 relative z-10">Целевые KPI</h4>
                      <div className="space-y-6 relative z-10">
                        {selectedSolution.kpis && selectedSolution.kpis.map((kpi: string, i: number) => (
                          <div key={i} className="flex items-start gap-3">
                            <div className="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center mt-0.5 shrink-0">
                              <ArrowRight size={10} className="text-white" />
                            </div>
                            <span className="text-sm font-bold leading-tight">{kpi}</span>
                          </div>
                        ))}
                      </div>

                      <div className="mt-10 pt-8 border-t border-white/10">
                        <div className="text-[10px] font-black text-white/60 uppercase tracking-[0.2em] mb-2">Экономика</div>
                        <div className="text-lg font-black leading-tight">{selectedSolution.roi_detail}</div>
                      </div>
                    </section>

                    {/* Stack Section */}
                    <section className="px-4">
                      <h4 className="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-4">Технологии</h4>
                      <div className="flex flex-wrap gap-2">
                        {selectedSolution.stack.split(',').map((s: string, i: number) => (
                          <span key={i} className="px-3 py-1.5 bg-slate-100 text-slate-600 rounded-lg text-[10px] font-bold uppercase tracking-widest">
                            {s.trim()}
                          </span>
                        ))}
                      </div>
                    </section>
                  </div>
                </div>
              </div>

              <div className="shrink-0 p-8 bg-slate-50 border-t border-slate-100 flex gap-4">
                <button 
                  onClick={() => setSelectedSolution(null)}
                  className="flex-1 h-14 rounded-2xl font-bold bg-slate-900 text-white hover:bg-slate-800 hover:shadow-xl transition-all flex items-center justify-center gap-2"
                >
                  Обсудить внедрение
                </button>
                <button 
                  onClick={() => setSelectedSolution(null)}
                  className="px-8 h-14 rounded-2xl font-bold bg-white border border-slate-200 text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-all"
                >
                  Закрыть
                </button>
              </div>
            </motion.div>
          </div>
        )}
      </AnimatePresence>
    </section>
  );
};


