                    animate={{ scale: [1, 1.15, 1], opacity: [0.1, 0.25, 0.1] }}
                    transition={{ duration: 4, repeat: Infinity, ease: "easeInOut" }}
                    className={`absolute inset-[-12px] blur-2xl rounded-full ${c.color.replace('bg-', 'bg-')}/30`}
                  />
                  
                  {/* Контейнер иконки */}
                  <div className={`relative w-14 h-14 bg-slate-950 border border-slate-800 rounded-2xl flex items-center justify-center text-white shadow-2xl group-hover:border-blue-500/40 transition-colors duration-500`}>
                    <c.icon size={28} strokeWidth={1.5} className="group-hover:text-blue-400 transition-colors" />
                    
                    {/* Технологические акценты по углам (Tesla Style) */}
                    <div className="absolute -top-1 -left-1 w-2 h-2 border-t border-l border-blue-500/0 group-hover:border-blue-500/60 opacity-0 group-hover:opacity-100 transition-all duration-500" />
                    <div className="absolute -bottom-1 -right-1 w-2 h-2 border-b border-r border-blue-500/0 group-hover:border-blue-500/60 opacity-0 group-hover:opacity-100 transition-all duration-500" />
                  </div>
                </div>

                <div className="text-right">
                  <span className="text-[10px] font-black text-slate-600 uppercase tracking-widest block mb-1">Case Study</span>
                  <span className="text-xs font-bold text-blue-400 uppercase tracking-widest">{c.id.replace('-', '_').toUpperCase()}</span>
                </div>
              </div>

              <h3 className="text-2xl font-bold text-white mb-4 leading-tight group-hover:text-blue-300 transition-colors relative z-10">
                {c.title}
              </h3>

              <div className="text-[10px] font-bold text-slate-600 uppercase tracking-widest mb-6 border-b border-slate-800 pb-4">
                {c.stack}
              </div>

              <div className="grid grid-cols-2 gap-4 mt-auto">
                {c.results.map((res, i) => (
                  <div key={i} className="p-4 bg-slate-800 rounded-2xl border border-slate-700">
                    <div className="text-2xl font-black text-white mb-1">{res.value}</div>
                    <div className="text-[10px] font-bold text-slate-400 uppercase leading-tight">{res.label}</div>
                  </div>
                ))}
              </div>
            </motion.div>
          ))}
        </div>
      </div>

      {/* Case Detail Modal */}
      <AnimatePresence>
        {selectedCase && (
          <div className="fixed inset-0 z-[120] flex items-center justify-center p-4 md:p-6">
            <motion.div 
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              onClick={() => setSelectedCase(null)}
              className="absolute inset-0 bg-slate-900/80 backdrop-blur-md"
            />
            <motion.div
              initial={{ opacity: 0, scale: 0.9, y: 40 }}
              animate={{ opacity: 1, scale: 1, y: 0 }}
              exit={{ opacity: 0, scale: 0.9, y: 40 }}
              className="relative w-full max-w-4xl bg-slate-950 rounded-[40px] shadow-2xl overflow-hidden flex flex-col max-h-[90vh] border border-slate-800"
            >
              {/* НОВАЯ ШАПКА МОДАЛКИ (Dark Tech Style) */}
              <div className={`shrink-0 h-40 md:h-56 bg-slate-900 p-8 md:p-12 flex items-end justify-between relative overflow-hidden`}>
                {/* Фоновое свечение в шапке */}
                <div className={`absolute -top-32 -left-32 w-80 h-80 ${selectedCase.color.replace('bg-', 'bg-')}/10 blur-[100px]`} />
                
                <div className="flex items-center gap-6 relative z-10">
                  {/* ИКОНКА В ШАПКЕ (Core Style) */}
                  <div className="relative">
                    <motion.div 
                      animate={{ scale: [1, 1.2, 1], opacity: [0.15, 0.35, 0.15] }}
                      transition={{ duration: 4, repeat: Infinity }}
                      className={`absolute inset-[-15px] blur-2xl rounded-full ${selectedCase.color.replace('bg-', 'bg-')}/40`}
                    />
                    <div className="w-20 h-20 md:w-24 md:h-24 bg-slate-950 border border-slate-800 rounded-3xl flex items-center justify-center text-white backdrop-blur-xl shadow-2xl relative">
                      <selectedCase.icon size={44} strokeWidth={1.5} className="md:w-12 md:h-12" />
                      {/* Уголки (как на карточках) */}
                      <div className="absolute -top-1 -left-1 w-3 h-3 border-t border-l border-blue-500/50" />
                      <div className="absolute -bottom-1 -right-1 w-3 h-3 border-b border-r border-blue-500/50" />
                    </div>
                  </div>

                  <div className="text-white">
                    <div className="text-[10px] font-black uppercase tracking-[0.4em] text-blue-400 mb-3">{selectedCase.id.replace('-', '_').toUpperCase()}</div>
                    <h3 className="text-2xl md:text-4xl font-bold leading-tight max-w-2xl tracking-tight">{selectedCase.title}</h3>
                  </div>
                </div>

                <button 
                  onClick={() => setSelectedCase(null)}
                  className="absolute top-8 right-8 w-12 h-12 bg-slate-950/50 rounded-full flex items-center justify-center text-slate-400 hover:text-white hover:bg-slate-800 transition-all border border-slate-800 backdrop-blur-md z-20"
                >
                  <X size={20} />
                </button>
              </div>
              
              <div className="p-8 md:p-12 overflow-y-auto custom-scrollbar bg-slate-950">
                <div className="grid grid-cols-1 lg:grid-cols-3 gap-12">
                  <div className="lg:col-span-2 space-y-12">
                    {/* Problem */}
                    <section>
                      <div className="flex items-center gap-4 mb-6">
                        <div className="w-10 h-10 rounded-2xl bg-blue-500/10 border border-blue-500/20 text-blue-400 flex items-center justify-center font-black text-sm">01</div>
                        <h4 className="text-lg font-bold text-white uppercase tracking-[0.2em]">Проблема</h4>
                      </div>
                      <p className="text-lg text-slate-400 leading-relaxed pl-14 font-medium">
                        {selectedCase.problem}
                      </p>
                    </section>

                    {/* Solution */}
                    <section>
                      <div className="flex items-center gap-4 mb-8">
                        <div className="w-10 h-10 rounded-2xl bg-blue-500/10 border border-blue-500/20 text-blue-400 flex items-center justify-center font-black text-sm">02</div>
                        <h4 className="text-lg font-bold text-white uppercase tracking-[0.2em]">Техническое решение</h4>
                      </div>
                      <div className="space-y-6 pl-14">
                        {selectedCase.solution.map((step: any, i: number) => (
                          <div key={i} className="relative pl-8 border-l border-slate-800 py-2">
                            <div className="absolute -left-[5px] top-4 w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_rgba(59,130,246,0.5)]" />
                            <div className="font-bold text-slate-200 mb-2 flex items-center gap-3">
                              <ArrowRight size={14} className="text-blue-500" />
                              {step.label}
                            </div>
                            <p className="text-slate-500 leading-relaxed text-sm">{step.text}</p>
                          </div>
                        ))}
                      </div>
                    </section>
                  </div>

                  <div className="space-y-8">
                    {/* Results */}
                    <section className="bg-slate-900/50 p-8 rounded-[40px] border border-slate-800 relative overflow-hidden">
                      {/* Мягкий фон для результатов */}
                      <div className={`absolute top-0 right-0 w-32 h-32 ${selectedCase.color.replace('bg-', 'bg-')}/5 blur-[60px]`} />
                      
                      <div className="flex items-center gap-4 mb-8 relative z-10">
                        <div className="w-10 h-10 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 flex items-center justify-center font-black text-sm">03</div>
                        <h4 className="text-lg font-bold text-white uppercase tracking-[0.2em]">Результат</h4>
                      </div>
                      <div className="space-y-6 relative z-10">
                        {selectedCase.results.map((res: any, i: number) => (
                          <div key={i} className="bg-slate-950/80 p-6 rounded-2xl border border-slate-800 shadow-xl group/res hover:border-emerald-500/30 transition-colors">
                            <div className="text-4xl font-black text-white mb-2 tracking-tighter group-hover/res:text-emerald-400 transition-colors">{res.value}</div>
                            <div className="text-[10px] font-bold text-slate-500 uppercase tracking-widest leading-tight">{res.label}</div>
                          </div>
                        ))}
                      </div>
                    </section>

                    {/* Stack */}
                    <section className="px-4">
                      <h4 className="text-[10px] font-black text-slate-500 uppercase tracking-[0.3em] mb-6">Технологический стек</h4>
                      <div className="flex flex-wrap gap-2">
                        {selectedCase.stack.split('|').map((s: string, i: number) => (
                          <span key={i} className="px-4 py-2 bg-slate-900 border border-slate-800 text-slate-400 rounded-xl text-[9px] font-bold uppercase tracking-widest hover:border-blue-500/30 transition-colors">
                            {s.trim()}
                          </span>
                        ))}
                      </div>
                    </section>
                  </div>
                </div>
              </div>
            </motion.div>
          </div>
        )}
      </AnimatePresence>
    </section>
  );
};

